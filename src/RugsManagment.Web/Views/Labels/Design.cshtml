@{
    ViewData["Title"] = "طراح برچسب";
    var templateId = ViewData["TemplateId"] as Guid?;
}
<div class="space-y-4">
    <div class="flex items-center gap-3">
        <a asp-action="Index" class="rounded-lg border border-outline-variant px-3 py-1.5 text-sm hover:bg-surface-container">→ بازگشت</a>
        <h1 class="text-2xl font-bold">طراح برچسب</h1>
    </div>
    @if (templateId.HasValue && templateId.Value != Guid.Empty)
    {
        <div data-island="label-designer" data-props='@Json.Serialize(new { templateId = templateId.Value })'></div>
    }
    else
    {
        <div data-island="label-designer"></div>
    }
</div>
