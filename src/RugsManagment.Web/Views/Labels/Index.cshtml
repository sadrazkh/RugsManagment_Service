@using System.Security.Claims
@using RugsManagment.Application.DTOs.Labels
@model IReadOnlyList<LabelTemplateDto>
@{
    ViewData["Title"] = "برچسب‌ها";
    var isAdmin = User.FindFirstValue(ClaimTypes.Role) == nameof(RugsManagment.Domain.Enums.UserRole.TenantAdmin);
}

<div class="space-y-5">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">قالب‌های برچسب</h1>
            <p class="text-sm text-on-surface-variant">طراحی و چاپ برچسب فرش با دادهٔ واقعی</p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Design" class="rounded-lg bg-primary px-4 py-2.5 font-semibold text-on-primary hover:opacity-90">+ برچسب جدید</a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="rounded-xl border border-dashed border-outline-variant bg-white p-10 text-center text-on-surface-variant">
            هنوز قالبی طراحی نشده است.
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            @foreach (var l in Model)
            {
                <div class="rounded-xl border border-outline-variant bg-white p-5 shadow-sm">
                    <div class="flex items-start justify-between gap-2">
                        <div>
                            <h2 class="font-bold">@l.Name</h2>
                            <p class="text-xs text-on-surface-variant" dir="ltr">@l.WidthMm×@l.HeightMm mm · @(l.Mode == RugsManagment.Domain.Enums.LabelMode.Html ? "HTML" : "بصری")</p>
                        </div>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="mt-4 flex gap-2">
                            <a asp-action="Design" asp-route-id="@l.Id" class="flex-1 rounded-lg border border-outline-variant px-3 py-2 text-center text-sm hover:bg-surface-container">ویرایش / چاپ</a>
                            <form asp-action="Delete" asp-route-id="@l.Id" method="post" onsubmit="return confirm('حذف این قالب؟')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rounded-lg border border-outline-variant px-3 py-2 text-sm text-error hover:bg-error-container">حذف</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
