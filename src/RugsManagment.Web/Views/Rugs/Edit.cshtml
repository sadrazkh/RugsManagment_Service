@{
    ViewData["Title"] = "ویرایش فرش";
    var rugId = (Guid)ViewData["RugId"]!;
}
<div class="mx-auto max-w-4xl space-y-5">
    <div class="flex items-center gap-3">
        <a asp-action="Details" asp-route-id="@rugId" class="rounded-lg border border-outline-variant px-3 py-1.5 text-sm hover:bg-surface-container">→ بازگشت</a>
        <h1 class="text-2xl font-bold">ویرایش فرش</h1>
    </div>
    <div data-island="rug-form" data-props='@Json.Serialize(new { rugId })'></div>
</div>
