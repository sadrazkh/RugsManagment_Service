@using RugsManagment.Application.DTOs.Rugs
@using RugsManagment.Domain.Enums
@using RugsManagment.Web.Support
@model IReadOnlyList<RugDto>
@{
    ViewData["Title"] = "فرش‌ها";
    var current = ViewData["StatusFilter"] as RugStatus?;
    (string label, RugStatus? val)[] filters =
    {
        ("همه", null),
        ("پیش‌نویس", RugStatus.Draft),
        ("در جریان", RugStatus.InProgress),
        ("آمادهٔ فروش", RugStatus.ReadyForSale),
        ("فروخته‌شده", RugStatus.Sold),
    };
}

<div class="space-y-5">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">فرش‌ها</h1>
            <p class="text-sm text-on-surface-variant">@Model.Count فرش</p>
        </div>
        <a asp-action="Create" class="rounded-lg bg-primary px-4 py-2.5 font-semibold text-on-primary hover:opacity-90">+ ثبت فرش</a>
    </div>

    <!-- فیلتر وضعیت -->
    <div class="flex flex-wrap gap-2">
        @foreach (var (label, val) in filters)
        {
            var active = current == val;
            <a asp-action="Index" asp-route-status="@val"
               class="rounded-full border px-3 py-1.5 text-sm @(active ? "border-primary bg-primary/10 text-primary" : "border-outline-variant text-on-surface-variant hover:bg-surface-container")">
                @label
            </a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="rounded-xl border border-dashed border-outline-variant bg-white p-10 text-center text-on-surface-variant">
            فرشی یافت نشد. با «ثبت فرش» اولین فرش را اضافه کنید.
        </div>
    }
    else
    {
        <!-- موبایل: کارت -->
        <div class="grid gap-3 md:hidden">
            @foreach (var r in Model)
            {
                var st = DisplayHelpers.RugStatus(r.Status);
                <a asp-action="Details" asp-route-id="@r.Id" class="block rounded-xl border border-outline-variant bg-white p-4 shadow-sm">
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex min-w-0 items-start gap-2">
                            <input type="checkbox" data-rug-select="@r.Id" onclick="event.stopPropagation()"
                                   class="mt-0.5 h-4 w-4 shrink-0 rounded border-outline-variant text-primary" />
                            <div class="min-w-0">
                                <div class="truncate font-semibold">@(string.IsNullOrEmpty(r.Title) ? "بدون عنوان" : r.Title)</div>
                                <div class="text-xs text-on-surface-variant" dir="ltr">@r.Sku</div>
                            </div>
                        </div>
                        <span class="shrink-0 rounded-full px-2.5 py-1 text-xs @st.Css">@st.Label</span>
                    </div>
                    <div class="mt-3 grid grid-cols-3 gap-2 text-center text-sm">
                        <div><div class="text-xs text-on-surface-variant">ابعاد</div><div dir="ltr">@DisplayHelpers.Number(r.WidthMeters)×@DisplayHelpers.Number(r.LengthMeters)</div></div>
                        <div><div class="text-xs text-on-surface-variant">مساحت</div><div dir="ltr">@DisplayHelpers.Number(r.AreaSquareMeters)</div></div>
                        <div><div class="text-xs text-on-surface-variant">مرحله</div><div class="truncate">@(r.CurrentStepNameFa ?? "—")</div></div>
                    </div>
                </a>
            }
        </div>

        <!-- دسکتاپ: جدول -->
        <div class="hidden overflow-hidden rounded-xl border border-outline-variant bg-white md:block">
            <table class="w-full text-sm">
                <thead class="bg-surface-container text-on-surface-variant">
                    <tr>
                        <th class="w-8 p-3"></th>
                        <th class="p-3 text-right font-medium">کد</th>
                        <th class="p-3 text-right font-medium">عنوان</th>
                        <th class="p-3 text-right font-medium">ابعاد (م)</th>
                        <th class="p-3 text-right font-medium">مساحت</th>
                        <th class="p-3 text-right font-medium">مرحلهٔ جاری</th>
                        <th class="p-3 text-right font-medium">وضعیت</th>
                        <th class="p-3 text-right font-medium">هزینهٔ کل</th>
                        <th class="p-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var st = DisplayHelpers.RugStatus(r.Status);
                        <tr class="border-t border-outline-variant hover:bg-surface-container/40">
                            <td class="p-3"><input type="checkbox" data-rug-select="@r.Id" class="h-4 w-4 rounded border-outline-variant text-primary" /></td>
                            <td class="p-3" dir="ltr">@r.Sku</td>
                            <td class="p-3 font-medium">@(string.IsNullOrEmpty(r.Title) ? "—" : r.Title)</td>
                            <td class="p-3" dir="ltr">@DisplayHelpers.Number(r.WidthMeters)×@DisplayHelpers.Number(r.LengthMeters)</td>
                            <td class="p-3" dir="ltr">@DisplayHelpers.Number(r.AreaSquareMeters)</td>
                            <td class="p-3">@(r.CurrentStepNameFa ?? "—")</td>
                            <td class="p-3"><span class="rounded-full px-2.5 py-1 text-xs @st.Css">@st.Label</span></td>
                            <td class="p-3" dir="ltr">@DisplayHelpers.Money(r.Costs.TotalInvestment)</td>
                            <td class="p-3 text-left">
                                @{
                                    var activeStep = r.WorkflowSteps.FirstOrDefault(x => x.Status == WorkflowStepStatus.InProgress);
                                }
                                <div class="flex justify-end gap-1.5">
                                    @if (activeStep is not null)
                                    {
                                        <button type="button" data-advance-rug="@r.Id" data-advance-step="@activeStep.Id"
                                                class="rounded-lg border border-primary px-3 py-1.5 text-xs text-primary hover:bg-primary/10">مرحلهٔ بعد ✓</button>
                                    }
                                    <a asp-action="Details" asp-route-id="@r.Id" class="rounded-lg border border-outline-variant px-3 py-1.5 text-xs hover:bg-surface-container">جزئیات</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* جزیرهٔ سبک برای دکمه‌های «مرحلهٔ بعد» داخل لیست *@
        <div data-island="list-quick-advance"></div>
        @* نوار عملیات دسته‌ای (انتخاب چند فرش) *@
        <div data-island="rug-bulk-toolbar"></div>
        <div class="h-16"></div> @* فضای خالی برای نوار چسبان پایین *@
    }
</div>
