@model IReadOnlyList<RugsManagment.Application.DTOs.Tenants.TenantDto>
@{
    ViewData["Title"] = "کارگاه‌ها";
}

<div class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">کارگاه‌ها</h1>
            <p class="text-sm text-on-surface-variant">@Model.Count کارگاه ثبت‌شده</p>
        </div>
        <a asp-action="Create" class="rounded-lg bg-primary px-4 py-2.5 font-semibold text-on-primary hover:opacity-90">+ کارگاه جدید</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="rounded-xl border border-dashed border-outline-variant bg-white p-10 text-center text-on-surface-variant">
            هنوز کارگاهی ثبت نشده است. با «کارگاه جدید» اولین فروشنده را بسازید.
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            @foreach (var t in Model)
            {
                <div class="rounded-xl border border-outline-variant bg-white p-5 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <h2 class="truncate font-bold text-on-surface">@t.Name</h2>
                            <p class="text-xs text-on-surface-variant" dir="ltr">@t.Slug</p>
                        </div>
                        @if (t.IsActive)
                        {
                            <span class="rounded-full bg-success/10 px-2.5 py-1 text-xs text-success">فعال</span>
                        }
                        else
                        {
                            <span class="rounded-full bg-error-container px-2.5 py-1 text-xs text-error">غیرفعال</span>
                        }
                    </div>
                    <dl class="mt-4 space-y-1 text-sm text-on-surface-variant">
                        @if (!string.IsNullOrEmpty(t.ContactPhone))
                        {
                            <div class="flex justify-between"><dt>تلفن</dt><dd dir="ltr">@t.ContactPhone</dd></div>
                        }
                        @if (!string.IsNullOrEmpty(t.ContactEmail))
                        {
                            <div class="flex justify-between"><dt>ایمیل</dt><dd dir="ltr">@t.ContactEmail</dd></div>
                        }
                    </dl>
                    <form asp-action="ToggleActive" asp-route-id="@t.Id" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full rounded-lg border border-outline-variant px-3 py-2 text-sm hover:bg-surface-container">
                            @(t.IsActive ? "غیرفعال کردن" : "فعال کردن")
                        </button>
                    </form>
                </div>
            }
        </div>
    }
</div>
