@using RugsManagment.Application.DTOs.Batches
@model IReadOnlyList<RugBatchDto>
@{
    ViewData["Title"] = "گروه‌ها";
}

<div class="space-y-5">
    <div>
        <h1 class="text-2xl font-bold">گروه‌ها / محموله‌ها</h1>
        <p class="text-sm text-on-surface-variant">فرش‌هایی که با هم پیش می‌روند (مثلاً محمولهٔ یک روز)</p>
    </div>

    <!-- ساخت گروه -->
    <form asp-action="Create" method="post" class="flex flex-wrap items-end gap-3 rounded-xl border border-outline-variant bg-white p-4 shadow-sm">
        @Html.AntiForgeryToken()
        <label class="block flex-1">
            <span class="mb-1 block text-sm">نام گروه</span>
            <input name="name" required placeholder="محمولهٔ ۱۴۰۳/۰۴/۱۵" class="w-full rounded-lg border border-outline-variant px-3 py-2.5 outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
        </label>
        <label class="block flex-1">
            <span class="mb-1 block text-sm">توضیح</span>
            <input name="description" class="w-full rounded-lg border border-outline-variant px-3 py-2.5 outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
        </label>
        <button type="submit" class="rounded-lg bg-primary px-5 py-2.5 font-semibold text-on-primary hover:opacity-90">+ ساخت گروه</button>
    </form>

    @if (Model.Count == 0)
    {
        <div class="rounded-xl border border-dashed border-outline-variant bg-white p-10 text-center text-on-surface-variant">
            هنوز گروهی ساخته نشده است.
        </div>
    }
    else
    {
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            @foreach (var b in Model)
            {
                <a asp-action="Details" asp-route-id="@b.Id" class="block rounded-xl border border-outline-variant bg-white p-5 shadow-sm hover:border-primary">
                    <div class="flex items-start justify-between gap-2">
                        <h2 class="font-bold">@b.Name</h2>
                        <span class="rounded-full bg-secondary-container px-2.5 py-1 text-xs text-on-secondary-container">@b.RugCount فرش</span>
                    </div>
                    @if (!string.IsNullOrEmpty(b.Description))
                    {
                        <p class="mt-1 text-sm text-on-surface-variant">@b.Description</p>
                    }
                    @if (!string.IsNullOrEmpty(b.CurrentStepSummary))
                    {
                        <p class="mt-3 text-xs text-on-surface-variant">مراحل جاری: @b.CurrentStepSummary</p>
                    }
                </a>
            }
        </div>
    }
</div>
