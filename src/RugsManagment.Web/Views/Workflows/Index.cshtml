@using System.Security.Claims
@using RugsManagment.Application.DTOs.Workflows
@model IReadOnlyList<WorkflowTemplateDto>
@{
    ViewData["Title"] = "گردش کار";
    var isAdmin = User.FindFirstValue(ClaimTypes.Role) == nameof(RugsManagment.Domain.Enums.UserRole.TenantAdmin);
}

<div class="space-y-5">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">قالب‌های گردش کار</h1>
            <p class="text-sm text-on-surface-variant">مسیرهای آمادهٔ فرایند که هنگام ثبت فرش انتخاب می‌شوند</p>
        </div>
        @if (isAdmin)
        {
            <a asp-action="Create" class="rounded-lg bg-primary px-4 py-2.5 font-semibold text-on-primary hover:opacity-90">+ قالب جدید</a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="rounded-xl border border-dashed border-outline-variant bg-white p-10 text-center text-on-surface-variant">
            هنوز قالبی تعریف نشده است.
        </div>
    }
    else
    {
        <div class="grid gap-4 md:grid-cols-2">
            @foreach (var t in Model)
            {
                <div class="rounded-xl border border-outline-variant bg-white p-5 shadow-sm">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <h2 class="font-bold">@t.Name @if (t.IsDefault) { <span class="ms-1 rounded-full bg-secondary-container px-2 py-0.5 text-xs text-on-secondary-container">پیش‌فرض</span> }</h2>
                            @if (!string.IsNullOrEmpty(t.Description))
                            {
                                <p class="text-sm text-on-surface-variant">@t.Description</p>
                            }
                        </div>
                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@t.Id" class="rounded-lg border border-outline-variant px-3 py-1.5 text-xs hover:bg-surface-container">ویرایش</a>
                        }
                    </div>
                    <ol class="mt-4 flex flex-wrap items-center gap-1.5 text-sm">
                        @foreach (var s in t.Steps)
                        {
                            <li class="rounded-lg bg-surface-container px-2.5 py-1 @(s.IsOptional ? "border border-dashed border-outline" : "")">@s.StepNameFa</li>
                            @if (s.OrderIndex < t.Steps.Count - 1)
                            {
                                <span class="text-on-surface-variant">←</span>
                            }
                        }
                    </ol>
                </div>
            }
        </div>
    }
</div>
